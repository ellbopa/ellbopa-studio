# Local example:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ellbopa_studio?schema=public"
# Production example (Neon/Supabase/Railway):
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# App URLs
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Auth.js / NextAuth
AUTH_SECRET="change-me"
NEXTAUTH_SECRET="change-me"
ADMIN_EMAILS="admin@ellbopastudio.com"

# OAuth providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# Stripe
STRIPE_SECRET_KEY="sk_test_change_me"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_change_me"
STRIPE_WEBHOOK_SECRET="whsec_change_me"

# PayPal Checkout
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
# sandbox for tests, live for production. PAYPAL_ENV is kept as legacy fallback.
PAYPAL_MODE="sandbox"
PAYPAL_ENV="sandbox"
PAYPAL_WEBHOOK_ID=""
# PayPal does not process DOP in every account. This converts RD$ to USD for PayPal Checkout.
PAYPAL_DOP_USD_RATE="60"

# Contact / brand
NEXT_PUBLIC_WHATSAPP_NUMBER="18095903643"

# Email SMTP. Resend SMTP example:
SMTP_HOST="smtp.resend.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="resend"
SMTP_PASS="re_xxxxxxxxxxxxxxxxx"
# Use onboarding@resend.dev for tests, then change to a verified domain sender.
EMAIL_FROM="Ellbopa Music <onboarding@resend.dev>"

# Optional future integrations
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
UPLOADTHING_TOKEN=""
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""
OPENAI_API_KEY=""
