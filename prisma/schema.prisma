generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ARTIST
  PRODUCER
  ENGINEER
  STUDIO
  ADMIN
}

enum ProductType {
  BEAT
  PRESET
  SOUND_KIT
  SERVICE
}

enum WorkStatus {
  PENDING
  PAID
  MIXING
  REVISION
  COMPLETED
  CANCELLED
}

enum SenderRole {
  CLIENT
  ADMIN
}

enum WalletTransactionType {
  SALE_EARNING
  PAYOUT_REQUEST
  PAYOUT_PAID
  ADJUSTMENT
}

enum PayoutStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

model User {
  id           String    @id @default(cuid())
  username     String?   @unique
  name         String?
  email        String    @unique
  emailVerified DateTime?
  verified     Boolean   @default(false)
  image        String?
  passwordHash String?
  phone        String?
  accountType  String?   @default("ARTIST")
  artistName   String?
  artistCount  Int?
  managedArtists String?
  role         Role      @default(ARTIST)
  onboardingCompleted Boolean @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  accounts     Account[]
  sessions     Session[]
  orders       Order[]
  bookings     Booking[]
  payments     Payment[]
  messages     Message[]
  products     Product[]
  favorites    Favorite[]
  posts        CommunityPost[]
  comments     CommunityComment[]
  followers    Follow[] @relation("FollowTarget")
  following    Follow[] @relation("FollowSource")
  reviewsGiven Review[] @relation("ReviewAuthor")
  reviewsReceived Review[] @relation("ReviewTarget")
  verificationCodes VerificationCode[]
  passwordResetTokens PasswordResetToken[]
  artistProfile ArtistProfile?
  producerProfile ProducerProfile?
  engineerProfile EngineerProfile?
  studioProfile StudioProfile?
  wallet       Wallet?
  walletTransactions WalletTransaction[]
  payoutRequests PayoutRequest[]
}

model ArtistProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  artistName   String?
  bio          String?
  location     String?
  genres       String?
  instagram    String?
  spotify      String?
  youtube      String?
  profileImage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProducerProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  displayName     String?
  artistName      String?
  bio             String?
  location        String?
  genres          String?
  profileImage    String?
  bannerImage     String?
  instagram       String?
  youtube         String?
  tiktok          String?
  spotify         String?
  website         String?
  startingPrice   Int?
  verified        Boolean  @default(false)
  acceptingOrders Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EngineerProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  displayName        String?
  bio                String?
  location           String?
  specialties        String?
  beforeAfterSamples String?
  startingPrice      Int?
  deliveryTime       String?
  revisions          Int?
  profileImage       String?
  bannerImage        String?
  acceptingOrders    Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StudioProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  studioName        String?
  bio               String?
  location          String?
  address           String?
  hourlyRate        Int?
  depositRequired   Int?
  openingHours      String?
  photos            String?
  equipment         String?
  services          String?
  acceptingBookings Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Product {
  id          String      @id @default(cuid())
  ownerId     String?
  slug        String?     @unique
  title       String
  type        ProductType
  genre       String?
  bpm         Int?
  musicalKey  String?
  mood        String?
  description String
  price       Int
  premiumPrice Int?
  exclusivePrice Int?
  popularity  Int         @default(0)
  audioUrl    String?
  imageUrl    String?
  fileUrl     String?
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  owner       User?       @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  licenses    License[]
  orders      Order[]
  favorites   Favorite[]
  views       ProductView[]

  @@index([type, active])
  @@index([genre])
  @@index([ownerId])
}

model License {
  id          String   @id @default(cuid())
  productId   String
  key         String
  title       String
  price       Int
  files       String
  terms       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, key])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("FollowSource", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("FollowTarget", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model CommunityPost {
  id        String   @id @default(cuid())
  userId    String
  text      String
  imageUrl  String?
  likes     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments  CommunityComment[]
}

model CommunityComment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  text      String
  createdAt DateTime @default(now())
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(cuid())
  authorId  String
  targetId  String
  rating    Int
  text      String
  createdAt DateTime @default(now())
  author    User     @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  target    User     @relation("ReviewTarget", fields: [targetId], references: [id], onDelete: Cascade)
}

model ProductView {
  id        String   @id @default(cuid())
  productId String
  userId    String?
  path      String?
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt])
}

model Order {
  id              String     @id @default(cuid())
  userId          String
  productId       String?
  serviceType     String?
  status          WorkStatus @default(PENDING)
  totalAmount     Int
  depositAmount   Int
  paidAmount      Int        @default(0)
  platformFeePercent Int     @default(20)
  platformFeeAmount  Int     @default(0)
  creatorEarnings    Int     @default(0)
  commissionProcessedAt DateTime?
  creatorId       String?
  notes           String?
  referenceArtist String?
  bpm             Int?
  musicalKey      String?
  genre           String?
  filesUrl        String?
  finalFilesUrl   String?
  createdAt       DateTime   @default(now())
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  product         Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)
  payments        Payment[]
  messages        Message[]
  walletTransaction WalletTransaction?
}

model Booking {
  id              String     @id @default(cuid())
  userId          String
  serviceType     String
  date            DateTime
  time            String
  status          WorkStatus @default(PENDING)
  depositRequired Int
  depositPaid     Int        @default(0)
  notes           String?
  createdAt       DateTime   @default(now())
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments        Payment[]
}

model Payment {
  id              String     @id @default(cuid())
  userId          String
  orderId         String?
  bookingId       String?
  stripeSessionId String     @unique
  paymentIntentId String?
  method          String     @default("STRIPE")
  amount          Int
  status          WorkStatus @default(PENDING)
  receiptUrl      String?
  createdAt       DateTime   @default(now())
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  order           Order?     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  booking         Booking?   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Wallet {
  id              String   @id @default(cuid())
  userId          String   @unique
  availableBalance Int    @default(0)
  pendingBalance   Int    @default(0)
  totalEarned      Int    @default(0)
  totalPaidOut     Int    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions     WalletTransaction[]
  payoutRequests   PayoutRequest[]
}

model WalletTransaction {
  id          String                @id @default(cuid())
  walletId    String
  userId      String
  orderId     String?               @unique
  payoutId    String?
  type        WalletTransactionType
  amount      Int
  platformFeeAmount Int             @default(0)
  grossAmount Int                   @default(0)
  description String?
  createdAt   DateTime              @default(now())
  wallet      Wallet                @relation(fields: [walletId], references: [id], onDelete: Cascade)
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  order       Order?                @relation(fields: [orderId], references: [id], onDelete: SetNull)
  payout      PayoutRequest?        @relation(fields: [payoutId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([walletId, createdAt])
}

model PayoutRequest {
  id        String       @id @default(cuid())
  walletId  String
  userId    String
  amount    Int
  method    String
  note      String?
  status    PayoutStatus @default(PENDING)
  adminNote String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  wallet    Wallet       @relation(fields: [walletId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model VerificationCode {
  id        String   @id @default(cuid())
  userId    String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, code])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Message {
  id         String     @id @default(cuid())
  userId     String
  orderId    String
  senderRole SenderRole
  text       String
  createdAt  DateTime   @default(now())
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  order      Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
}
