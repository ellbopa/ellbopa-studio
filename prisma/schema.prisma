generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ARTIST
  PRODUCER
  ENGINEER
  STUDIO
  ADMIN
}

enum ProductType {
  BEAT
  PRESET
  SERVICE
}

enum WorkStatus {
  PENDING
  PAID
  MIXING
  REVISION
  COMPLETED
  CANCELLED
}

enum SenderRole {
  CLIENT
  ADMIN
}

model User {
  id           String    @id @default(cuid())
  name         String?
  email        String    @unique
  emailVerified DateTime?
  verified     Boolean   @default(false)
  image        String?
  passwordHash String?
  phone        String?
  accountType  String?   @default("ARTIST")
  artistName   String?
  artistCount  Int?
  managedArtists String?
  role         Role      @default(ARTIST)
  onboardingCompleted Boolean @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  accounts     Account[]
  sessions     Session[]
  orders       Order[]
  bookings     Booking[]
  payments     Payment[]
  messages     Message[]
  verificationCodes VerificationCode[]
  passwordResetTokens PasswordResetToken[]
  artistProfile ArtistProfile?
  producerProfile ProducerProfile?
  engineerProfile EngineerProfile?
  studioProfile StudioProfile?
}

model ArtistProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  artistName   String?
  bio          String?
  location     String?
  genres       String?
  instagram    String?
  spotify      String?
  youtube      String?
  profileImage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProducerProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  displayName     String?
  artistName      String?
  bio             String?
  location        String?
  genres          String?
  profileImage    String?
  bannerImage     String?
  instagram       String?
  youtube         String?
  tiktok          String?
  spotify         String?
  website         String?
  startingPrice   Int?
  verified        Boolean  @default(false)
  acceptingOrders Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EngineerProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  displayName        String?
  bio                String?
  location           String?
  specialties        String?
  beforeAfterSamples String?
  startingPrice      Int?
  deliveryTime       String?
  revisions          Int?
  profileImage       String?
  bannerImage        String?
  acceptingOrders    Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StudioProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  studioName        String?
  bio               String?
  location          String?
  address           String?
  hourlyRate        Int?
  depositRequired   Int?
  openingHours      String?
  photos            String?
  equipment         String?
  services          String?
  acceptingBookings Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Product {
  id          String      @id @default(cuid())
  title       String
  type        ProductType
  genre       String?
  bpm         Int?
  musicalKey  String?
  mood        String?
  description String
  price       Int
  audioUrl    String?
  imageUrl    String?
  fileUrl     String?
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  orders      Order[]
}

model Order {
  id              String     @id @default(cuid())
  userId          String
  productId       String?
  serviceType     String?
  status          WorkStatus @default(PENDING)
  totalAmount     Int
  depositAmount   Int
  paidAmount      Int        @default(0)
  notes           String?
  referenceArtist String?
  bpm             Int?
  musicalKey      String?
  genre           String?
  filesUrl        String?
  finalFilesUrl   String?
  createdAt       DateTime   @default(now())
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  product         Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)
  payments        Payment[]
  messages        Message[]
}

model Booking {
  id              String     @id @default(cuid())
  userId          String
  serviceType     String
  date            DateTime
  time            String
  status          WorkStatus @default(PENDING)
  depositRequired Int
  depositPaid     Int        @default(0)
  notes           String?
  createdAt       DateTime   @default(now())
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments        Payment[]
}

model Payment {
  id              String     @id @default(cuid())
  userId          String
  orderId         String?
  bookingId       String?
  stripeSessionId String     @unique
  amount          Int
  status          WorkStatus @default(PENDING)
  receiptUrl      String?
  createdAt       DateTime   @default(now())
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  order           Order?     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  booking         Booking?   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model VerificationCode {
  id        String   @id @default(cuid())
  userId    String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, code])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Message {
  id         String     @id @default(cuid())
  userId     String
  orderId    String
  senderRole SenderRole
  text       String
  createdAt  DateTime   @default(now())
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  order      Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
}
